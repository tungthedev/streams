{
  "name": "prisma-streams",
  "version": "0.2.0",
  "private": true,
  "description": "Prisma Streams is a Bun + TypeScript implementation of the Durable Streams HTTP protocol, with a local development server for Prisma CLI integration.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tungthedev/streams.git"
  },
  "bugs": {
    "url": "https://github.com/tungthedev/streams/issues"
  },
  "homepage": "https://github.com/tungthedev/streams/tree/main/docs",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6",
    "node": ">=22.0.0"
  },
  "files": [
    "LICENSE",
    "docs/",
    "tsconfig.json",
    "tsconfig.build.types.json",
    "scripts/check-result-policy.sh",
    "scripts/build-local-node.mjs",
    "scripts/build-npm-packages.mjs",
    "scripts/test-node-local-package.mjs",
    "scripts/test-bun-local-package.mjs",
    "scripts/test-bun-server-package.mjs",
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "bun run build:npm-packages",
    "build:local:node": "node scripts/build-local-node.mjs",
    "build:npm-packages": "node scripts/build-npm-packages.mjs",
    "build:compute-bundle": "bun run scripts/compute/build-bundle.mjs",
    "build:compute-demo-bundle": "bun run scripts/compute/build-demo-bundle.mjs",
    "prepack": "bun run build:npm-packages",
    "start": "bun run src/server.ts",
    "start:full": "bun run src/server.ts",
    "start:local": "bun run src/local/cli.ts start --name default",
    "local:status": "bun run src/local/cli.ts status --name default",
    "local:stop": "bun run src/local/cli.ts stop --name default",
    "local:reset": "bun run src/local/cli.ts reset --name default",
    "test": "bun test",
    "test:ci": "node scripts/run-bun-tests-sequential.mjs",
    "test:large-index-filter": "DS_LARGE_INDEX_FILTER=1 DS_LARGE_INDEX_FILTER_SEGMENT_BYTES=16777216 bun test test/large_index_filter.test.ts",
    "typecheck": "tsc --noEmit",
    "test:node-local-package": "node scripts/test-node-local-package.mjs",
    "test:bun-local-package": "node scripts/test-bun-local-package.mjs",
    "test:bun-server-package": "node scripts/test-bun-server-package.mjs",
    "verify": "bun run check:result-policy && bun run check:storage-boundaries && bun run typecheck && bun test",
    "verify:ci": "bun run check:result-policy && bun run check:storage-boundaries && bun run typecheck && bun run test:ci",
    "check:result-policy": "bash scripts/check-result-policy.sh",
    "check:storage-boundaries": "bash scripts/check-storage-boundaries.sh",
    "test:conformance": "vitest run -c vitest.conformance.config.ts",
    "test:conformance:local": "vitest run -c vitest.conformance.local.config.ts",
    "bench:synth": "bun run experiments/bench/synth.ts",
    "demo:ingest": "bun run experiments/demo/wal_demo_ingest.ts",
    "demo:subscribe": "bun run experiments/demo/wal_demo_subscribe.ts",
    "demo:live-fields": "bun run experiments/demo/live_fields_app.ts",
    "demo:gharchive": "bun run experiments/demo/gharchive_demo.ts",
    "demo:compute-verify": "bun run experiments/demo/compute/verify.ts"
  },
  "exports": {
    "./local": {
      "types": "./dist/types/local/index.d.ts",
      "default": "./dist/local/index.js"
    },
    "./local/internal/daemon": {
      "types": "./dist/types/local/daemon.d.ts",
      "default": "./dist/local/daemon.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@durable-streams/server-conformance-tests": "^0.2.1",
    "@durable-streams/state": "0.2.5",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.6",
    "fast-check": "^3.14.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@durable-streams/client": "^0.2.1",
    "ajv": "^8.12.0",
    "better-result": "^2.7.0",
    "env-paths": "^3.0.0",
    "pg": "^8.22.0",
    "proper-lockfile": "^4.1.2"
  }
}
